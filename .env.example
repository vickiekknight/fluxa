# Copy to .env and fill in your keys: cp .env.example .env

# Gemini API key — LLM backbone for Fluxa reward generation
# Get yours at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# NGC API key — required to pull Isaac Sim base image
# Get yours at: https://ngc.nvidia.com/setup/api-key
# Then run: docker login nvcr.io -u '$oauthtoken' -p $NGC_API_KEY
NGC_API_KEY=your_ngc_api_key_here
